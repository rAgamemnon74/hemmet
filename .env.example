# Database
DATABASE_URL="postgresql://hemmet:hemmet_dev@localhost:5432/hemmet?schema=public"

# NextAuth / Auth.js
NEXTAUTH_URL="http://localhost:3000"
AUTH_SECRET="change-me-in-production"
AUTH_TRUST_HOST=true

# Email — konfigureras per inkorg i /installningar/epost
# Dessa env-vars är för lokal utveckling (Mailpit)
MAIL_IMAP_HOST="localhost"
MAIL_IMAP_PORT=1143
MAIL_SMTP_HOST="localhost"
MAIL_SMTP_PORT=1025
MAIL_DEV_MODE=true

# Encryption (AES-256 — 32 bytes as hex, 64 chars. Generate: openssl rand -hex 32)
ENCRYPTION_KEY=""

# SMS Provider (twilio or 46elks)
SMS_PROVIDER=""
# Twilio
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""
# 46elks
ELKS_API_KEY=""
ELKS_API_SECRET=""
ELKS_FROM="Hemmet"

# File storage
UPLOAD_DIR="./uploads"
